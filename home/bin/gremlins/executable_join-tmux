#!/usr/bin/env python3

"""
Create or attach a tmux session
"""

import argparse
import logging
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path

DRYRUN = False
HOME = Path(os.path.expanduser("~"))


class Logger:
    logger = None

    @classmethod
    def enable_logging(cls, log_location):
        kwargs = {}
        if log_location:
            kwargs["filename"] = Path(log_location).resolve()

        else:
            kwargs["stream"] = sys.stderr

        logging.basicConfig(datefmt="%m-%d %H:%M:%S", format="%(asctime)s %(message)s", **kwargs)
        cls.logger = logging.getLogger(__name__)
        logging.root.setLevel(logging.DEBUG)
        cls.logger.setLevel(logging.DEBUG)

    @classmethod
    def debug(cls, message):
        if cls.logger:
            cls.logger.debug(message)

    @classmethod
    def fail(cls, msg, exit_code=1):
        print(msg, file=sys.stderr)
        if cls.logger:
            cls.logger.error(msg)

        if os.environ.get("SSH_TTY") and sys.stdout.isatty():  # pragma: no cover
            # Avoid exiting too early when new ghostty -> ssh session created
            input("Press ENTER to continue...")

        sys.exit(exit_code)

    @classmethod
    def abort_if(cls, condition, msg: str, dryrun=None):
        if condition:
            if dryrun is None:
                dryrun = DRYRUN

            if dryrun:
                print(f"Would abort: {msg}")
                return

            cls.fail(msg)


def which(command):
    exe = shutil.which(command)
    if not exe:
        for folder in ("/opt/homebrew/bin", "/home/linuxbrew/.linuxbrew/bin"):
            full_path = os.path.join(folder, command)
            if os.path.exists(full_path):
                exe = full_path
                break

    return exe


def run_command(exe: str, *args: str, do_exec=False, dryrun=None, fatal=True):
    Logger.abort_if(not exe, f"'{exe}' does not exist")
    if dryrun is None:
        dryrun = DRYRUN

    command = os.path.basename(exe)
    description = "%s %s" % (command, " ".join(str(x) for x in args))
    if do_exec:
        description = f"exec {description}"

    if dryrun:
        verb = "exec" if do_exec else "run"
        print(f"Would {verb}: {description}")
        return None if do_exec else subprocess.CompletedProcess(args=args, returncode=0, stdout="", stderr="")

    full_args = [exe, *args]
    if do_exec:  # pragma: no cover
        Logger.debug(f"Exec: {description}")
        os.execv(exe, [exe, *args])  # noqa: S606

    Logger.debug(f"Running: {description}")
    result = subprocess.run(full_args, capture_output=True, text=True)  # noqa: S603
    Logger.abort_if(fatal and result.returncode, f"'{description}' failed with exit code {result.returncode}:\n{result.stderr}")
    return result


def is_already_running_in_tmux():
    if os.environ.get("TMUX"):
        Logger.debug("TMUX env var is set")
        return True

    if os.environ.get("SSH_TTY"):
        current_term = os.environ.get("TERM")
        Logger.debug(f"TERM: {current_term}")
        return current_term and "tmux" in current_term


def detected_term_emulator():
    if "GHOSTTY_BIN_DIR" in os.environ:
        return "ghostty"

    if "ITERM_PROFILE" in os.environ:
        return "iterm"


class TmuxRunner:
    def __init__(self, session_name):
        self.given_session_name = session_name
        self.session_name = session_name
        self.detected_term_emulator = detected_term_emulator()
        Logger.debug(f"Detected term: {self.detected_term_emulator}")
        if self.detected_term_emulator:
            self.session_name += f"-{self.detected_term_emulator}"

        self.tmux_path = which("tmux")

    def join_or_attach(self):
        r = self.run("has-session", "-t", self.session_name, dryrun=False, fatal=False)
        if r.returncode:
            self.setup_session()

        self.run("attach-session", "-t", self.session_name, do_exec=True)

    def setup_session(self):
        Logger.debug(f"Setting up tmux session: {self.session_name}")
        self.run("new-session", "-d", "-s", self.session_name, "-c", HOME)
        folders = list(self.session_folders())
        Logger.debug(f"{len(folders)} session folders are configured")
        for folder in self.session_folders():
            time.sleep(0.01)
            self.run("new-window", "-t", self.session_name, "-c", folder)

        if not DRYRUN:  # pragma: no cover
            subprocess.Popen(  # noqa: S602
                f"sleep 1 && {self.tmux_path} kill-session -C -t {self.session_name}",
                shell=True,
                start_new_session=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )

    def session_folders(self):
        text = "~/dev\n~/github\n~/tmp"
        cfg_folder = Path(os.getenv("TMUX_CONFIG", str(HOME / ".local"))).resolve()
        for basename in (self.session_name, self.given_session_name):
            cfg = cfg_folder / f"tmux.{basename}.cfg"
            if cfg.exists():
                text = cfg.read_text().strip()
                break

        for line in text.splitlines():
            line = line.strip()
            if line and not line.startswith("#"):
                if line.startswith("~"):
                    line = os.path.expanduser(line)

                elif not line.startswith("/"):
                    line = str(HOME / line)

                yield line

    def run(self, *args, do_exec=False, dryrun=None, fatal=True):
        return run_command(self.tmux_path, *args, do_exec=do_exec, dryrun=dryrun, fatal=fatal)


def main(args=None):
    global DRYRUN

    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--debug", "-v", action="store_true", help="Log debug info")
    parser.add_argument("--dryrun", "-n", action="store_true", help="Perform a dryrun")
    parser.add_argument("--log", help="Log to specified file")
    parser.add_argument("session_name", help="tmux session name")
    args = parser.parse_args(args=args)

    DRYRUN = args.dryrun
    if args.debug or args.log:
        Logger.enable_logging(args.log)

    Logger.debug(f"-- {args}")
    tmux = TmuxRunner(args.session_name)
    Logger.abort_if(not tmux.tmux_path, "tmux is not installed")
    Logger.abort_if(is_already_running_in_tmux(), "Already in tmux")
    tmux.join_or_attach()


if __name__ == "__main__":
    sys.exit(main())
