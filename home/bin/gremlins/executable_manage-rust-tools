#!/bin/zsh -eu

typeset -gr cargo_home="${CARGO_HOME:-$HOME/.cargo}"
typeset -gr cargo_bin_dir="$cargo_home/bin"
typeset -gr cargo_env_file="$cargo_home/env"
typeset -gr cargo_installed_file="$cargo_home/.crates.toml"

typeset -ga desired_rust_packages=(
    cargo-update
    bat
    dua-cli
    eza
    fd-find
    git-delta
    ripgrep
    tokei
    tre-command
    zoxide
)

typeset -ga avoid_compile=(
    uv
)

[[ "$USER" == "zoran" ]] && desired_rust_packages+=(uv)

typeset -gr default_binstall_strategies="crate-meta-data,compile"
typeset -gr metadata_only_binstall_strategies="crate-meta-data"

prepend_to_path() {
    local dir="$1"

    [[ -d "$dir" ]] || return 0

    case ":$PATH:" in
        *":$dir:"*) ;;
        *) export PATH="$dir:$PATH" ;;
    esac
}

ensure_cargo_path() {
    prepend_to_path "$cargo_bin_dir"

    if ! command -v cargo > /dev/null && [[ -f "$cargo_env_file" ]]; then
        source "$cargo_env_file"
        prepend_to_path "$cargo_bin_dir"
    fi
}

ensure_rustup() {
    if [[ ! -x "$cargo_bin_dir/rustup" ]]; then
        echo Installing rustup
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path --profile minimal
    fi

    ensure_cargo_path
    command -v cargo > /dev/null
    command -v rustup > /dev/null
}

ensure_cargo_binstall() {
    if [[ ! -x "$cargo_bin_dir/cargo-binstall" ]]; then
        echo Installing cargo-binstall
        curl -L --proto '=https' --tlsv1.2 -sSf https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh | bash
    fi

    ensure_cargo_path
    command -v cargo-binstall > /dev/null
}

cargo_installed_packages() {
    [[ -r "$cargo_installed_file" ]] || return 0
    cargo install --list | awk '/^[^ ]+ v[^ ]+:$/ { print $1 }'
}

install_rust_package() {
    local pkg_name="$1"
    local strategies="$default_binstall_strategies"

    if (( ${avoid_compile[(Ie)$pkg_name]} != 0 )); then
        strategies="$metadata_only_binstall_strategies"
    fi

    BINSTALL_STRATEGIES="$strategies" cargo binstall --no-confirm -- "$pkg_name" ||
        print "WARN: skipped $pkg_name: no binary"
}

bootstrap_rust_cli_tools() {
    local -a installed_packages
    local pkg_name

    ensure_rustup
    ensure_cargo_binstall

    installed_packages=($(cargo_installed_packages))
    for pkg_name in "${desired_rust_packages[@]}"; do
        if (( ${installed_packages[(Ie)$pkg_name]} == 0 )); then
            install_rust_package "$pkg_name"
        fi
    done
}

upgrade_rust_cli_tools() {
    local -a installed_packages
    local pkg_name

    ensure_rustup
    rustup self update
    rustup update
    ensure_cargo_binstall

    installed_packages=($(cargo_installed_packages))
    for pkg_name in "${installed_packages[@]}"; do
        install_rust_package "$pkg_name"
    done
}

case "${1:-}" in
    bootstrap) bootstrap_rust_cli_tools ;;
    upgrade) upgrade_rust_cli_tools ;;
    *)
        print -u2 "usage: $0 bootstrap|upgrade"
        exit 1
        ;;
esac
