#!/bin/zsh -eu

"$HOME/bin/gremlins/manage-rust-tools"

if command -v brew > /dev/null; then
    # Avoid running brew update on the very first run (where brew may not yet have been picked up in PATH)
    export HOMEBREW_NO_ENV_HINTS=1
    # Leave self-updating casks to their own updaters while maintaining fonts, plugins, and similar casks.
    export HOMEBREW_NO_UPGRADE_AUTO_UPDATES_CASKS=1
    brew update --quiet
    brew upgrade --quiet --yes
    brew cleanup --quiet --prune=all
fi

"$HOME/bin/gremlins/regenerate-completions"
