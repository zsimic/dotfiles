#!/bin/zsh -eu

typeset -gr comp_dir="$HOME/.local/share/zsh/site-functions"
typeset -gr zcompdump_dir="$HOME/.cache/zsh"
typeset -g temp_dir=

cleanup() {
    if [[ -n "$temp_dir" && -d "$temp_dir" ]]; then
        rm -rf -- "$temp_dir"
    fi
}

ensure_dirs() {
    mkdir -p "$comp_dir" "$zcompdump_dir"
}

prepare_temp_dir() {
    temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/regenerate-completions.XXXXXX")"
}

render_completion() {
    local target="$1"
    shift

    local tmp_file="$temp_dir/$target"
    print -r -- "regen $target: '$*'"
    "$@" > "$tmp_file"
    [[ -s "$tmp_file" ]]
    mv -- "$tmp_file" "$comp_dir/$target"
}

fetch_completion() {
    local target="$1"
    local url="$2"
    local tmp_file="$temp_dir/$target"

    print -r -- "regen $target: from $url"
    curl -fsSL "$url" -o "$tmp_file"
    [[ -s "$tmp_file" ]]
    mv -- "$tmp_file" "$comp_dir/$target"
}

render_completion_to_dir() {
    local target="$1"
    shift

    print -r -- "regen $target: '$* --out-dir $temp_dir'"
    "$@" --out-dir "$temp_dir"
    [[ -s "$temp_dir/$target" ]]
    mv -- "$temp_dir/$target" "$comp_dir/$target"
}

clear_zcompdump() {
    local -a dump_files

    setopt local_options null_glob
    dump_files=("$zcompdump_dir"/zcompdump-*)
    if (( ${#dump_files[@]} )); then
        rm -f -- "${dump_files[@]}"
    fi
}

regenerate_completions() {
    # Keep one completion source per configured tool so any interface break fails early.
    # Remove a line here when the tool leaves this dotfiles set.
    # Keep instructions alphabetically sorted by tool.
    # Note: brew-installed tools should already come with completions handled by brew (if not present: tool probably doesn't have completions)

    render_completion_to_dir _atuin atuin gen-completions --shell zsh
    render_completion _bat bat --completion zsh
    fetch_completion _delta https://raw.githubusercontent.com/dandavison/delta/HEAD/etc/completion/completion.zsh
    # dua: no maintained completion source wired in here yet.
    fetch_completion _eza https://raw.githubusercontent.com/eza-community/eza/HEAD/completions/zsh/_eza
    render_completion _fd fd --gen-completions zsh
    render_completion _rg rg --generate complete-zsh
    render_completion _rustup rustup completions zsh
    # tokei: upstream no longer ships a checked-in completion source, and no supported `tokei completion` command was found.
    # tre: no shell completion subcommand is exposed; keep only if this changes.
    render_completion _uv uv generate-shell-completion zsh
    render_completion _xh xh --generate complete-zsh
    fetch_completion _zoxide https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/contrib/completions/_zoxide

    # Brew tools (listed here as a reminder... so we don't look again)
    # duf: upstream CLI exposes no completion subcommand, and upstream does not ship a checked-in zsh completion source.
    # tmux: upstream README only points to an external bash-completion file; tmux itself ships no checked-in zsh completion or generator.
}

refresh_zcompdump() {
    clear_zcompdump
    zsh -ilc 'echo zcompdump regenerated'
}

main() {
    trap cleanup EXIT INT TERM
    ensure_dirs
    prepare_temp_dir
    regenerate_completions
    refresh_zcompdump
    echo completions are in $comp_dir
}

main "$@"
