#!/bin/zsh -eu

COMP_DIR="$HOME/.local/share/zsh/site-functions"

# Keep one completion command per configured tool so any interface break fails early.
# Remove a line here when the tool is removed from this dotfiles set.
# Keep instructions sorted by tool, ie: same order as in `home/.chezmoiscripts/run_onchange_after_01-monthly-upgrade.sh.tmpl`

set -x
bat --completion zsh > "$COMP_DIR/_bat"
curl -fsSL https://raw.githubusercontent.com/dandavison/delta/HEAD/etc/completion/completion.zsh -o "$COMP_DIR/_delta"
# dua completion zsh > "$COMP_DIR/_dua"
curl -fsSL https://raw.githubusercontent.com/eza-community/eza/HEAD/completions/zsh/_eza -o "$COMP_DIR/_eza"
fd --gen-completions zsh > "$COMP_DIR/_fd"
rg --generate complete-zsh > "$COMP_DIR/_rg"
rustup completions zsh > "$COMP_DIR/_rustup"
# tokei: upstream no longer ships a checked-in completion source, and no supported `tokei completion` command was found.
# tre: no shell completion subcommand is exposed; keep only if this changes.
uv generate-shell-completion zsh > "$COMP_DIR/_uv"

rm -f "$HOME/.cache/zsh/zcompdump-"*
set +x
echo
echo "Done! Start a new shell session"
