#!/usr/bin/env python3

"""
Create or attach a tmux session
"""

import argparse
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path

DRYRUN = False
HOME = Path(os.path.expanduser("~"))
K_GHOSTTY = "ghostty"
K_ITERM = "iterm"
KNOWN_EMULATORS = {"g": K_GHOSTTY, "i": K_ITERM}
ITERM_PROFILE_KEYS = ("New Bookmarks", "Profiles", "Bookmarks")


def abort_if(condition, msg: str):
    if condition:
        print(f"Aborting: {msg}")
        if os.environ.get("SSH_TTY"):
            # Avoid exiting too early when new ghostty -> ssh session created
            input("Press ENTER to continue...")

        sys.exit(1)


def which(command):
    exe = shutil.which(command)
    if not exe:
        for folder in ("/opt/homebrew/bin", "/home/linuxbrew/.linuxbrew/bin"):
            full_path = os.path.join(folder, command)
            if os.path.exists(full_path):
                exe = full_path
                break

    return exe


def run_command(exe: str, *args: str, do_exec=False, dryrun=None, fatal=True):
    abort_if(not exe, f"'{exe}' does not exist")
    if dryrun is None:
        dryrun = DRYRUN

    command = os.path.basename(exe)
    description = "%s %s" % (command, " ".join(str(x) for x in args))
    if do_exec:
        description = f"exec {description}"

    if dryrun:
        print(f"Would run: {description}")
        return None if do_exec else subprocess.CompletedProcess(args=args, returncode=0, stdout="", stderr="")

    full_args = [exe, *args]
    if do_exec:
        os.execv(exe, [exe, *args])  # noqa: S606

    result = subprocess.run(full_args, capture_output=True, text=True)  # noqa: S603
    abort_if(fatal and result.returncode, f"'{description}' failed with exit code {result.returncode}:\n{result.stderr}")
    return result


def is_already_running_in_tmux():
    if os.environ.get("TMUX"):
        return True

    if os.environ.get("SSH_TTY"):
        current_term = os.environ.get("TERM")
        return current_term and "tmux" in current_term


def detected_term_emulator():
    if "GHOSTTY_BIN_DIR" in os.environ or "PYCHARM_HOSTED" in os.environ:
        return K_GHOSTTY

    if "ITERM_PROFILE" in os.environ:
        return K_ITERM


class TmuxRunner:
    def __init__(self, session_name):
        self.given_session_name = session_name
        self.session_name = session_name
        self.detected_term_emulator = detected_term_emulator()
        if self.detected_term_emulator:
            self.session_name += f"-{self.detected_term_emulator}"

        self.tmux_path = which("tmux")
        abort_if(not self.tmux_path, "tmux is not installed")

    def __repr__(self):
        return self.session_name

    def join_or_attach(self):
        r = self.run("has-session", "-t", self.session_name, dryrun=False, fatal=False)
        if r.returncode:
            self.setup_session()

        self.run("attach-session", "-t", self.session_name, do_exec=True)

    def setup_session(self):
        self.run("new-session", "-d", "-s", self.session_name, "-c", HOME)
        for folder in self.session_folders():
            time.sleep(0.01)
            self.run("new-window", "-t", self.session_name, "-c", folder)

        if not DRYRUN:
            subprocess.Popen(  # noqa: S602
                f"sleep 1 && {self.tmux_path} kill-session -C -t {self.session_name}",
                shell=True,
                start_new_session=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )

    def session_folders(self):
        text = "~/dev\n~/github\n~/tmp"
        for basename in (self.session_name, self.given_session_name):
            cfg = Path(f"{HOME}/.local/tmux.{basename}.cfg")
            if cfg.exists():
                text = cfg.read_text().strip()
                break

        for line in text.splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue

            if line.startswith("~"):
                line = os.path.expanduser(line)

            elif not line.startswith("/"):
                line = str(HOME / line)

            yield line

    def run(self, *args, do_exec=False, dryrun=None, fatal=True):
        return run_command(self.tmux_path, *args, do_exec=do_exec, dryrun=dryrun, fatal=fatal)


def launch_ghostty(session_name):
    abort_if(not Path("/Applications/Ghostty.app").is_dir(), "ghostty is not installed")
    cf = HOME / f".config/ghostty/{session_name}.conf"
    abort_if(not cf.exists(), f"No ghostty config: {cf}")
    run_command("/usr/bin/open", "-na", "Ghostty", "--args", f"--class={session_name}", f"--config-file={cf}", do_exec=True)


def find_iterm_profile(profile_name):
    import plistlib

    r = run_command("defaults", "read", "com.googlecode.iterm2", "PrefsCustomFolder", dryrun=False)
    file_path = Path(r.stdout.strip()) / "com.googlecode.iterm2.plist"
    abort_if(not file_path.exists(), f"No iterm file: {file_path}")
    with file_path.open("rb") as fp:
        prefs = plistlib.load(fp)

    return find_iterm_profile_in_prefs(prefs, profile_name)


def find_iterm_profile_in_prefs(prefs, profile_name):
    for key in ITERM_PROFILE_KEYS:
        profiles = prefs.get(key, [])
        if not isinstance(profiles, list):
            continue

        for profile in profiles:
            if not isinstance(profile, dict):
                continue

            if profile.get("Name") == profile_name:
                return profile


def launch_iterm(session_name):
    abort_if(not Path("/Applications/iTerm.app").is_dir(), "iTerm is not installed")
    has_profile = find_iterm_profile(session_name)
    abort_if(not has_profile, f"No profile '{session_name}' in iterm2 plist")
    run_command("/usr/bin/open", "-a", "iTerm")
    run_command("/usr/bin/osascript", "-e", f'tell application "iTerm" to create window with profile "{session_name}"')


def main(args=None):
    """
    Start or join a tmux session
    Examples:
        yo-mux main
        yo-mux g main
        yo-mux -t ghostty main
    """
    global DRYRUN

    parser = argparse.ArgumentParser(description=main.__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    parser.add_argument("--dryrun", "-n", action="store_true", help="Perform a dryrun")
    parser.add_argument("--term-emulator", "-t", choices=KNOWN_EMULATORS.values(), help="Terminal emulator to use")
    parser.add_argument("term_short", nargs="?", choices=KNOWN_EMULATORS.keys(), help="Terminal emulator to use")
    parser.add_argument("session_name", help="tmux session name")
    args = parser.parse_args(args=args)

    DRYRUN = args.dryrun
    tmux = TmuxRunner(args.session_name)
    session_name = args.session_name
    term_emulator = args.term_emulator
    if not term_emulator and args.term_short:
        term_emulator = KNOWN_EMULATORS[args.term_short]

    if term_emulator:
        # Clear env vars to avoid polluting sessions (eg: clear ghostty env vars when starting iterm)
        groomed_env = {"PATH": "/usr/bin:/bin:/sbin", "TERM": "xterm-256color"}
        groomed_env.update({k: v for k, v in os.environ.items() if v and k in ("HOME", "LANG", "LOGNAME", "USER")})
        os.environ.clear()
        os.environ.update(groomed_env)
        if term_emulator == K_GHOSTTY:
            return launch_ghostty(session_name)

        return launch_iterm(session_name)

    abort_if(is_already_running_in_tmux(), "Already in tmux")
    tmux.join_or_attach()


if __name__ == "__main__":  # pragma: no cover
    sys.exit(main())
