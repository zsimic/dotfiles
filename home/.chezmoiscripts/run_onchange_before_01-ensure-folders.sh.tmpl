#!/usr/bin/env zsh

set -e

ensure_folders() {
    for folder in "$@"; do
        [ -d "$folder" ] || mkdir -p "$folder"
    done
}

ensure_folders ~/.cache/zsh ~/.local/bin ~/.local/config ~/.local/share/zsh/site-functions ~/.local/state/history

{{ if not .headless -}}
ensure_folders ~/dev ~/github ~/tmp
{{- end }}
